#!/usr/bin/env python3
"""
validate-docs — Consistency checker for Adwi documentation vs code.

Checks that authoritative facts in README.md, CLAUDE.md, and other docs
agree with ground truth from code and config files.

Exits 0 if all checks pass; exits 1 if any FAIL.

Usage:
  python3 bin/validate-docs            # run all checks, print results
  python3 bin/validate-docs --strict   # also exit 1 on WARNs
"""

from __future__ import annotations

import datetime
import json
import re
import sys
import urllib.request
from pathlib import Path

WORKSPACE    = Path.home() / "SuneelWorkSpace"
README       = WORKSPACE / "README.md"
CLAUDE_MD    = WORKSPACE / "CLAUDE.md"
CLI_PATH     = WORKSPACE / "adwi" / "adwi_cli.py"
CAPS_PATH    = WORKSPACE / "adwi" / "capabilities.json"
MANIFEST     = WORKSPACE / "adwi" / "system_manifest.json"
PORTS_JSON   = WORKSPACE / "adwi" / "config" / "infra_ports.json"
COMPOSE      = WORKSPACE / "adwi" / "infra" / "docker" / "docker-compose.yml"
MASTER_RPT   = WORKSPACE / "adwi" / "logs" / "simeval" / "MASTER_REPORT_v2.md"
PRIMING_FILE = WORKSPACE / "adwi" / "docs" / "LLM_SYSTEM_PRIMING.md"

STRICT = "--strict" in sys.argv

results: list[tuple[str, str, str]] = []  # (status, check_id, message)


def check(status: str, check_id: str, message: str) -> None:
    results.append((status, check_id, message))
    icon = {"PASS": "✓", "FAIL": "✗", "WARN": "⚠", "SKIP": "·"}[status]
    print(f"  {icon} [{check_id}] {message}")


def extract_commands() -> list[str]:
    cmds: set[str] = set()
    if CLI_PATH.exists():
        src = CLI_PATH.read_text(errors="ignore")
        cmds.update(re.findall(r'line\.startswith\("(/[a-z][a-z0-9-]+)"', src))
        cmds.update(re.findall(r'line == "(/[a-z][a-z0-9-]+)"', src))
        for group in re.findall(r'line in \(([^)]+)\)', src):
            cmds.update(re.findall(r'"(/[a-z][a-z0-9-]+)"', group))
    if CAPS_PATH.exists():
        try:
            caps = json.loads(CAPS_PATH.read_text())
            entries = caps if isinstance(caps, list) else caps.get("capabilities", [])
            for c in entries:
                n = (c.get("command") or c.get("name", "")).strip()
                token = n.split()[0] if n else ""
                if token.startswith("/"):
                    cmds.add(token)
        except Exception:
            pass
    return sorted(cmds)


def extract_intent_count() -> int:
    if not CLI_PATH.exists():
        return 0
    src = CLI_PATH.read_text(errors="ignore")
    m = re.search(r"_ALL_INTENTS\s*=\s*\[(.*?)\]", src, re.S)
    if m:
        cnt = len(re.findall(r'"[\w_]+"', m.group(1)))
        if cnt:
            return cnt
    return 0


def live_fixture_count() -> int | None:
    try:
        req = urllib.request.Request("http://localhost:6333/collections/nlu_fixtures")
        with urllib.request.urlopen(req, timeout=3) as r:
            d = json.loads(r.read())
            n = (d.get("result") or {}).get("points_count")
            return int(n) if n is not None else None
    except Exception:
        return None


def readme_text() -> str:
    return README.read_text() if README.exists() else ""


def run_checks() -> None:
    readme = readme_text()
    true_commands = extract_commands()
    true_cmd_count = len(true_commands)
    true_intent_count = extract_intent_count()

    # ── Command count checks ─────────────────────────────────────────────────

    # AUTO:COMMANDS section
    m = re.search(r"<!-- AUTO:COMMANDS -->.*?\*\*(\d+) registered commands", readme, re.S)
    if m:
        readme_count = int(m.group(1))
        if readme_count == true_cmd_count:
            check("PASS", "CMD-001", f"AUTO:COMMANDS count matches code: {true_cmd_count}")
        else:
            check("FAIL", "CMD-001", f"AUTO:COMMANDS says {readme_count} commands but code has {true_cmd_count} — run bin/auto-update-readme --force")
    else:
        check("WARN", "CMD-001", "AUTO:COMMANDS marker not found in README.md")

    # Table of Contents
    m2 = re.search(r"All (\d+)\+ commands", readme)
    if m2:
        toc_count = int(m2.group(1))
        if abs(toc_count - true_cmd_count) <= 5:
            check("PASS", "CMD-002", f"TOC command count ({toc_count}+) is within 5 of actual ({true_cmd_count})")
        else:
            check("FAIL", "CMD-002", f"TOC says {toc_count}+ commands but actual is {true_cmd_count}")
    else:
        check("SKIP", "CMD-002", "TOC command count pattern not found")

    # Directory tree annotation
    m3 = re.search(r"adwi_cli\.py.*?(\d+) commands", readme)
    if m3:
        tree_count = int(m3.group(1))
        if abs(tree_count - true_cmd_count) <= 5:
            check("PASS", "CMD-003", f"Directory tree command count ({tree_count}) is within 5 of actual ({true_cmd_count})")
        else:
            check("FAIL", "CMD-003", f"Directory tree says {tree_count} commands but actual is {true_cmd_count} — update §6")

    # Phase 5 entry
    m4 = re.search(r"\| 5 \|.*?(\d+)-command registry", readme)
    if m4:
        p5_count = int(m4.group(1))
        if p5_count == true_cmd_count:
            check("PASS", "CMD-004", f"Phase 5 command count is current: {p5_count}")
        else:
            check("FAIL", "CMD-004", f"Phase 5 says {p5_count}-command registry but actual is {true_cmd_count} — run bin/auto-update-readme --force")
    else:
        check("SKIP", "CMD-004", "Phase 5 pattern not found in README")

    # ── NLU fixture count checks ─────────────────────────────────────────────

    fixture_count = live_fixture_count()
    if fixture_count is None:
        check("SKIP", "NLU-001", "Qdrant not reachable — skipping live fixture count checks")
    else:
        # AUTO:NLU section
        m = re.search(r"<!-- AUTO:NLU -->.*?(\d+) fixtures", readme, re.S)
        if m:
            readme_fixtures = int(m.group(1))
            if readme_fixtures == fixture_count:
                check("PASS", "NLU-001", f"AUTO:NLU fixture count matches Qdrant: {fixture_count}")
            else:
                check("FAIL", "NLU-001", f"AUTO:NLU says {readme_fixtures} fixtures but Qdrant has {fixture_count} — run bin/auto-update-readme --force")
        else:
            check("WARN", "NLU-001", "AUTO:NLU marker not found in README.md")

        # Phase 7
        m7 = re.search(r"\| 7 \|.*?(\d+)-fixture", readme)
        if m7:
            p7_fixtures = int(m7.group(1))
            if p7_fixtures == fixture_count:
                check("PASS", "NLU-002", f"Phase 7 fixture count is current: {p7_fixtures}")
            else:
                check("FAIL", "NLU-002", f"Phase 7 says {p7_fixtures}-fixture but Qdrant has {fixture_count}")
        else:
            check("SKIP", "NLU-002", "Phase 7 pattern not found in README")

        # Directory tree annotation (memory.py)
        m_tree = re.search(r"memory\.py.*?(\d+) NLU fixtures", readme)
        if m_tree:
            tree_fixtures = int(m_tree.group(1))
            if tree_fixtures == fixture_count:
                check("PASS", "NLU-003", f"Directory tree fixture count matches: {tree_fixtures}")
            else:
                check("FAIL", "NLU-003", f"Directory tree says {tree_fixtures} NLU fixtures but Qdrant has {fixture_count} — update §6")

    # ── Intent count checks ──────────────────────────────────────────────────

    if true_intent_count:
        m = re.search(r"(\d+) intent classes", readme)
        if m:
            readme_intents = int(m.group(1))
            if readme_intents == true_intent_count:
                check("PASS", "NLU-004", f"Intent class count matches: {true_intent_count}")
            else:
                check("FAIL", "NLU-004", f"README says {readme_intents} intent classes but _ALL_INTENTS has {true_intent_count}")
        else:
            check("SKIP", "NLU-004", "Intent class count not found in README")

    # ── Docker SERVICES section ──────────────────────────────────────────────

    m = re.search(r"<!-- AUTO:SERVICES -->.*?<!-- /AUTO:SERVICES -->", readme, re.S)
    if m:
        services_block = m.group(0)
        if "| :1 |" in services_block or ":1 |" in services_block:
            check("FAIL", "SVC-001", "AUTO:SERVICES shows ':1' port — regex bug in extract_services(). Run bin/auto-update-readme --force")
        else:
            check("PASS", "SVC-001", "AUTO:SERVICES port values look valid")
    else:
        check("SKIP", "SVC-001", "AUTO:SERVICES marker not found")

    # ── manifest freshness ───────────────────────────────────────────────────

    if MANIFEST.exists():
        try:
            mf = json.loads(MANIFEST.read_text())
            mf_count = mf.get("command_registry", {}).get("total_commands", 0)
            if mf_count == true_cmd_count:
                check("PASS", "MAN-001", f"system_manifest.json command count matches: {mf_count}")
            else:
                check("WARN", "MAN-001", f"system_manifest.json has {mf_count} commands but actual is {true_cmd_count} — run bin/generate-manifest")
            mf_intents = mf.get("nlu_pipeline", {}).get("intent_count", 0)
            if mf_intents == true_intent_count:
                check("PASS", "MAN-002", f"system_manifest.json intent count matches: {mf_intents}")
            else:
                check("WARN", "MAN-002", f"system_manifest.json has {mf_intents} intents but actual is {true_intent_count} — run bin/generate-manifest")
        except Exception as e:
            check("WARN", "MAN-001", f"Could not parse system_manifest.json: {e}")
    else:
        check("WARN", "MAN-001", "adwi/system_manifest.json not found — run bin/generate-manifest")

    # ── README header / priming claim ───────────────────────────────────────

    if "All sections are authoritative and kept" in readme:
        check("WARN", "PRIME-001",
              "README.md header claims 'all sections authoritative' — this is misleading as §6 directory tree has static/stale annotations. Consider nuancing this claim.")
    else:
        check("PASS", "PRIME-001", "README header does not make overly broad 'all authoritative' claim")

    # ── Port registry vs docker-compose cross-check ─────────────────────────

    if PORTS_JSON.exists() and COMPOSE.exists():
        try:
            registry = json.loads(PORTS_JSON.read_text())
            registry_ports = {str(e["port"]) for e in registry.get("ports", [])}
            compose_src = COMPOSE.read_text()
            compose_ports = set(re.findall(r':(\d{2,5}):\d{2,5}', compose_src))
            missing = compose_ports - registry_ports
            if missing:
                check("FAIL", "PORT-001",
                      f"docker-compose ports not in config/infra_ports.json: {sorted(missing)} — add them to the registry")
            else:
                check("PASS", "PORT-001",
                      f"All {len(compose_ports)} docker-compose host ports are registered in config/infra_ports.json")
        except Exception as e:
            check("WARN", "PORT-001", f"Could not cross-check port registry: {e}")
    elif not PORTS_JSON.exists():
        check("WARN", "PORT-001", "config/infra_ports.json not found — run bin/generate-manifest or create it")
    else:
        check("SKIP", "PORT-001", "docker-compose.yml not found")

    # ── INFRA_PORTS section reads from JSON (not hardcoded) ──────────────────

    auto_readme_bin = WORKSPACE / "adwi" / "bin" / "auto-update-readme"
    auto_readme_src = auto_readme_bin.read_text(errors="ignore") if auto_readme_bin.exists() else ""
    if "PORTS_PATH" in auto_readme_src and "infra_ports.json" in auto_readme_src:
        check("PASS", "PORT-002", "build_infra_ports_section() reads from config/infra_ports.json (not hardcoded)")
    else:
        check("WARN", "PORT-002", "build_infra_ports_section() may still be using hardcoded PORTS list — verify bin/auto-update-readme")

    # ── CLAUDE.md stale-value checks ─────────────────────────────────────────

    if CLAUDE_MD.exists():
        claude = CLAUDE_MD.read_text()
        # Intent count
        m_cl = re.search(r"(\d+) intent classes", claude)
        if m_cl:
            cl_intents = int(m_cl.group(1))
            if cl_intents == true_intent_count:
                check("PASS", "CLAUDE-001", f"CLAUDE.md intent class count matches: {cl_intents}")
            else:
                check("FAIL", "CLAUDE-001", f"CLAUDE.md says {cl_intents} intent classes but _ALL_INTENTS has {true_intent_count}")
        # Command count
        m_cl2 = re.search(r"REPL, (\d+) commands", claude)
        if m_cl2:
            cl_cmds = int(m_cl2.group(1))
            if abs(cl_cmds - true_cmd_count) <= 5:
                check("PASS", "CLAUDE-002", f"CLAUDE.md command count ({cl_cmds}) is within 5 of actual ({true_cmd_count})")
            else:
                check("FAIL", "CLAUDE-002", f"CLAUDE.md says {cl_cmds} commands but actual is {true_cmd_count}")
        # Stale MASTER_REPORT label
        if "Current NLU quality state" in claude:
            check("FAIL", "CLAUDE-003",
                  "CLAUDE.md labels MASTER_REPORT_v2.md as 'Current NLU quality state' — it is stale. Update the label.")
        else:
            check("PASS", "CLAUDE-003", "CLAUDE.md does not present MASTER_REPORT_v2.md as current")
    else:
        check("SKIP", "CLAUDE-001", "CLAUDE.md not found")

    # ── LLM_SYSTEM_PRIMING.md fact checks ───────────────────────────────────
    # This file is the cold-start oracle for external models. Its numeric claims
    # must stay in sync with the authoritative code sources. All ground-truth
    # values (true_cmd_count, true_intent_count, fixture_count) are already
    # computed above; we just verify the priming file agrees with them.

    if PRIMING_FILE.exists():
        priming = PRIMING_FILE.read_text()

        # Command count
        m = re.search(r"\*\*Total commands:\*\*\s*(\d+)", priming)
        if m:
            pr_cmds = int(m.group(1))
            if pr_cmds == true_cmd_count:
                check("PASS", "PRIMEFILE-001",
                      f"LLM_SYSTEM_PRIMING.md command count matches code: {pr_cmds}")
            else:
                check("FAIL", "PRIMEFILE-001",
                      f"LLM_SYSTEM_PRIMING.md says {pr_cmds} commands but code has {true_cmd_count}"
                      " — update CURRENT SYSTEM STATE in LLM_SYSTEM_PRIMING.md")
        else:
            check("WARN", "PRIMEFILE-001",
                  "Could not find '**Total commands:**' in LLM_SYSTEM_PRIMING.md")

        # Intent count
        m = re.search(r"\*\*Intent classes:\*\*\s*(\d+)", priming)
        if m:
            pr_intents = int(m.group(1))
            if pr_intents == true_intent_count:
                check("PASS", "PRIMEFILE-002",
                      f"LLM_SYSTEM_PRIMING.md intent count matches code: {pr_intents}")
            else:
                check("FAIL", "PRIMEFILE-002",
                      f"LLM_SYSTEM_PRIMING.md says {pr_intents} intent classes but _ALL_INTENTS has {true_intent_count}"
                      " — update CURRENT SYSTEM STATE in LLM_SYSTEM_PRIMING.md")
        else:
            check("WARN", "PRIMEFILE-002",
                  "Could not find '**Intent classes:**' in LLM_SYSTEM_PRIMING.md")

        # Qdrant fixture count (only when Qdrant is reachable)
        if fixture_count is not None:
            m = re.search(r"\*\*Qdrant fixtures:\*\*\s*(\d+)", priming)
            if m:
                pr_fixtures = int(m.group(1))
                if pr_fixtures == fixture_count:
                    check("PASS", "PRIMEFILE-003",
                          f"LLM_SYSTEM_PRIMING.md Qdrant fixture count matches live: {pr_fixtures}")
                else:
                    check("FAIL", "PRIMEFILE-003",
                          f"LLM_SYSTEM_PRIMING.md says {pr_fixtures} fixtures but Qdrant has {fixture_count}"
                          " — update CURRENT SYSTEM STATE in LLM_SYSTEM_PRIMING.md")
            else:
                check("WARN", "PRIMEFILE-003",
                      "Could not find '**Qdrant fixtures:**' in LLM_SYSTEM_PRIMING.md")
        else:
            check("SKIP", "PRIMEFILE-003",
                  "Qdrant not reachable — skipping priming fixture count check")

        # LAST VERIFIED date freshness (warn >14 days, fail >30 days)
        m = re.search(r"LAST VERIFIED.*?(\d{4}-\d{2}-\d{2})", priming)
        if m:
            try:
                verified_date = datetime.date.fromisoformat(m.group(1))
                age_days = (datetime.date.today() - verified_date).days
                if age_days <= 14:
                    check("PASS", "PRIMEFILE-004",
                          f"LLM_SYSTEM_PRIMING.md LAST VERIFIED is {age_days} day(s) old ({m.group(1)})")
                elif age_days <= 30:
                    check("WARN", "PRIMEFILE-004",
                          f"LLM_SYSTEM_PRIMING.md LAST VERIFIED is {age_days} days old"
                          " — update after next significant system change")
                else:
                    check("FAIL", "PRIMEFILE-004",
                          f"LLM_SYSTEM_PRIMING.md LAST VERIFIED is {age_days} days old ({m.group(1)})"
                          " — update the date and verify all values are current")
            except ValueError:
                check("WARN", "PRIMEFILE-004",
                      f"Could not parse LAST VERIFIED date in LLM_SYSTEM_PRIMING.md: {m.group(1)}")
        else:
            check("WARN", "PRIMEFILE-004",
                  "Could not find LAST VERIFIED date in LLM_SYSTEM_PRIMING.md")

    else:
        check("WARN", "PRIMEFILE-001",
              "adwi/docs/LLM_SYSTEM_PRIMING.md not found — external model priming is unavailable")

    # ── MASTER_REPORT staleness banner check ─────────────────────────────────

    if MASTER_RPT.exists():
        rpt = MASTER_RPT.read_text()
        if "STALE" in rpt or "stale" in rpt.lower():
            check("WARN", "STALE-001",
                  "MASTER_REPORT_v2.md has a STALE banner — regenerate with generate_master_report.py")
        elif "No safety breaches" in rpt or "Safety breaches | 0" in rpt or "Safety breaches: 0" in rpt:
            check("PASS", "STALE-001", "MASTER_REPORT_v2.md is current (no STALE banner, 0 safety breaches)")
        else:
            check("WARN", "STALE-001",
                  "MASTER_REPORT_v2.md has no STALE banner but safety breach status unclear — verify §6")
    else:
        check("SKIP", "STALE-001", "MASTER_REPORT_v2.md not found")

    # ── §6 directory tree label check ────────────────────────────────────────

    if "MANUALLY MAINTAINED" in readme:
        check("PASS", "STATIC-001", "README.md §6 has MANUALLY MAINTAINED label")
    else:
        check("WARN", "STATIC-001", "README.md §6 directory tree has no MANUALLY MAINTAINED label — readers may assume it is auto-generated")

    # ── Syntax check on adwi_cli.py ─────────────────────────────────────────

    import subprocess
    r = subprocess.run(["python3", "-m", "py_compile", str(CLI_PATH)], capture_output=True)
    if r.returncode == 0:
        check("PASS", "SYNTAX-001", "adwi/adwi_cli.py compiles without errors")
    else:
        check("FAIL", "SYNTAX-001", f"adwi/adwi_cli.py has syntax errors: {r.stderr.decode()[:100]}")


# ── Summary ──────────────────────────────────────────────────────────────────

def main() -> int:
    print("Adwi docs consistency check\n")
    run_checks()
    passes  = sum(1 for s, _, _ in results if s == "PASS")
    warns   = sum(1 for s, _, _ in results if s == "WARN")
    fails   = sum(1 for s, _, _ in results if s == "FAIL")
    skips   = sum(1 for s, _, _ in results if s == "SKIP")
    print(f"\n  {passes} PASS  {warns} WARN  {fails} FAIL  {skips} SKIP")
    if fails:
        print("  Fix FAILs by re-running bin/auto-update-readme --force and bin/generate-manifest")
    if not fails and not warns:
        print("  All checks passed — docs are consistent with code.")
    if fails:
        return 1
    if STRICT and warns:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
