# Adwi Workspace .gitignore — auto-managed by adwi /backup-enable
# NEVER commit secrets, credentials, or runtime data.

# ── Secrets and credentials (CRITICAL) ──────────────────────────────
secrets/
**/.env
**/secrets.local.env
**/*token*
**/*secret*
**/*credentials*
**/*.pem
**/*.p12
**/*.pfx
**/*.key
**/id_rsa
**/id_ed25519
**/.netrc
**/.npmrc
**/gmail-token.json
**/google-token.json

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node ────────────────────────────────────────────────────────────
node_modules/
.npm/
*.lock

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# ── Docker runtime data (large, contains runtime secrets) ───────────
adwi/infra/docker/open-webui-data/
adwi/infra/docker/n8n-data/
adwi/infra/docker/searxng-data/
adwi/infra/docker/qdrant-data/
adwi/infra/docker/data/
adwi/services/mcp/qdrant-data/

# ── Home Assistant runtime data ──────────────────────────────────────
adwi/infra/docker/homeassistant-data/

# ── High-volume log directories ──────────────────────────────────────
adwi/notes/clipboard-command-logs/
adwi/notes/open-webui-sync-logs/
adwi/notes/adwi-action-logs/
adwi/notes/adwi-repair-logs/backups/
adwi/notes/daily-status/
adwi/notes/maintenance-logs/
adwi/notes/self-heal-logs/
adwi/notes/secrets-logs/
adwi/notes/adwi-trace-logs/
adwi/notes/git-backup-logs/
adwi/notes/system-inspections/
adwi/logs/overnight/

# ── AI model files (large binaries) ─────────────────────────────────
*.gguf
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.model
models/
ollama-blobs/

# ── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Runtime state files ──────────────────────────────────────────────
*.pid
adwi/services/command-api/api.pid
adwi/services/mcp/workspace.db
adwi/memory.db
adwi/knowledge.db
adwi/knowledge.db-shm
adwi/knowledge.db-wal
adwi/rag-db/
adwi/.readme-snapshot.json
adwi/cache/
adwi/scheduled_sends.json
adwi/followup_reminders.json
adwi/gmail_rules.json
adwi/bin/*.backup.*

# ── Misc ─────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.env.local

# ── Config env (API tokens) ──
adwi/config/.env
# adwi/config/.env.example is intentionally tracked (safe template, no real values)

# ── Obsidian vault runtime files ──
# workspace.json / graph.json — volatile UI state (open files, window layout, graph positions)
# app.json / appearance.json — empty defaults, not meaningful to track
# core-plugins.json is tracked (stable plugin list useful for new machines)
obsidian-vault/.obsidian/workspace.json
obsidian-vault/.obsidian/workspace-mobile.json
obsidian-vault/.obsidian/graph.json
obsidian-vault/.obsidian/app.json
obsidian-vault/.obsidian/appearance.json

# ── Runtime logs and failure DBs ─────────────────────────────────────────────
adwi/logs/adwi_nlu_fast.jsonl
adwi/logs/simlab_failures.db
logs/adwi_nlu_fast.jsonl
logs/simlab_failures.db

# ── E2E auto-loop runtime state (live job state, not evidence) ────────────────
adwi/notes/e2e-auto-loop/status.json
adwi/notes/e2e-auto-loop/e2e-*/

# ── Eval routing result snapshots (ephemeral, auto-generated) ────────────────
adwi/evals/routing-results-*.json

# ── Eval session result directories (large/regenerable) ──────────────────────
# Tracked: MASTER_REPORT_v2.md, fix_backlog_v2.json, *.py harnesses
# Ignored: large raw result dirs (thousands of jsonl rows, regenerable)
adwi/logs/simeval/large-*/
adwi/logs/simeval/large-p2-*/
adwi/logs/simeval/session-*/
adwi/logs/simeval/__pycache__/
adwi/logs/simlab/

# ── Nightly eval session artifacts (large/regenerable) ───────────────────────
# Tracked: 00_morning_brief.md, 01_repair_backlog.md (markdown reports)
# Ignored: raw JSONL results, per-session dirs (too large, fully regenerable)
adwi/logs/nightly/[0-9]*/nlu_results.jsonl
adwi/logs/nightly/[0-9]*/scenarios.jsonl
adwi/logs/nightly/[0-9]*/phoenix_upload.jsonl
adwi/logs/nightly/__pycache__/
adwi/logs/nightly-eval.stdout.log
adwi/logs/nightly-eval.stderr.log
adwi/logs/nightly-eval.lock

# ── Eval tool generated output (not committed) ───────────────────────────────
adwi/eval/frameworks/scenarios/generated/
adwi/eval/promptfoo/results/
adwi/eval/playwright/results/
adwi/eval/playwright/test-results/
adwi/eval/k6/results/
adwi/eval/promptfoo/node_modules/
adwi/eval/playwright/node_modules/
adwi/eval/__pycache__/
adwi/eval/nightly/__pycache__/
adwi/eval/giskard/__pycache__/
adwi/eval/deepeval/__pycache__/
adwi/eval/deepeval/.deepeval/

# ── Langfuse (optional, runtime data) ────────────────────────────────────────
# adwi/config/langfuse/docker-compose.langfuse.yml is tracked (template)
# Runtime DB and credentials are not
langfuse_db_data/

# ── adwi/config/eval/nightly.local.yaml — machine-local overrides ─────────────────
adwi/config/eval/nightly.local.yaml

# ── Watcher runtime state (regenerable per-machine) ──────────────────────────────
adwi/services/watchers/*/uploaded-state.json

# ── Ollama runtime files (cache, history, generated keys) ────────────────────────
# n8n workflow definitions and adwi tools NOT under ollama/ — safe to ignore whole tree
ollama/
