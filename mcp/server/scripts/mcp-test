#!/bin/sh
# Run a compact functional test of the workspace-brain MCP subsystem.
set -eu
# Resolve symlinks to get the real directory of this script
TARGET="$0"
while [ -L "$TARGET" ]; do
    DIR="$(dirname "$TARGET")"
    TARGET="$(readlink "$TARGET")"
    case "$TARGET" in
        /*) ;;
        *) TARGET="$DIR/$TARGET" ;;
    esac
done
MCP_ROOT="$(cd "$(dirname "$TARGET")/../.." && pwd)"
SERVER="$MCP_ROOT/server/main.py"
WORKSPACE="$HOME/SuneelWorkSpace"

echo "=== workspace-brain MCP Tests ==="
PASS=0; FAIL=0

run_test() {
    NAME="$1"
    CMD="$2"
    if eval "$CMD" >/dev/null 2>&1; then
        echo "  [PASS] $NAME"
        PASS=$((PASS+1))
    else
        echo "  [FAIL] $NAME"
        FAIL=$((FAIL+1))
    fi
}

# 1. Config files valid JSON
run_test "server_config.json valid" "python3 -c \"import json; json.load(open('$MCP_ROOT/server/config/server_config.json'))\""
run_test "tool_policies.json valid" "python3 -c \"import json; json.load(open('$MCP_ROOT/server/config/tool_policies.json'))\""
run_test "resource_map.json valid" "python3 -c \"import json; json.load(open('$MCP_ROOT/server/config/resource_map.json'))\""

# 2. mcp package importable via uv
run_test "mcp importable via uv" "uv run --with-requirements '$MCP_ROOT/server/requirements.txt' python3 -c 'import mcp'"

# 3. Index readable
run_test "SQLite index readable" "python3 -c \"import sqlite3; c=sqlite3.connect('$MCP_ROOT/server/storage/memory_index.db'); c.execute('SELECT COUNT(*) FROM entries')\""

# 4. Index has entries
COUNT="$(python3 -c "import sqlite3; c=sqlite3.connect('$MCP_ROOT/server/storage/memory_index.db'); print(c.execute('SELECT COUNT(*) FROM entries').fetchone()[0])" 2>/dev/null || echo 0)"
if [ "${COUNT:-0}" -gt 0 ] 2>/dev/null; then
    echo "  [PASS] Index has $COUNT entries"
    PASS=$((PASS+1))
else
    echo "  [FAIL] Index is empty (run mcp-reindex)"
    FAIL=$((FAIL+1))
fi

# 5. Source files accessible
run_test "MEMORY.md readable" "test -f '$WORKSPACE/agent-system/memory/MEMORY.md'"
run_test "CURRENT_STATE.json readable" "test -f '$WORKSPACE/agent-system/state/CURRENT_STATE.json'"
run_test "WORKSPACE_HEALTH.json readable" "test -f '$WORKSPACE/agent-system/state/WORKSPACE_HEALTH.json'"

# 6. Claude registration
run_test "Claude has workspace-brain" \
    "python3 -c \"import json; d=json.load(open('$HOME/.claude/settings.json')); assert 'workspace-brain' in d.get('mcpServers',{})\""

# 7. Codex registration
run_test "Codex has workspace-brain" "grep -q 'workspace-brain' '$HOME/.codex/config.toml'"

# 8. Log dir writable
run_test "Log dir writable" "test -w '$MCP_ROOT/server/logs'"

# 9. Python inline: read a workspace file
run_test "Read workspace file (inline)" "python3 -c \"
import pathlib
p = pathlib.Path('$WORKSPACE/agent-system/state/CURRENT_STATE.json')
import json
d = json.loads(p.read_text())
assert 'workspace_root' in d or 'status' in d
\""

# 10. Write/append to safe test area (dry)
run_test "Write permission to state file" "python3 -c \"
import pathlib, json
p = pathlib.Path('$MCP_ROOT/server/state/mcp_state.json')
d = json.loads(p.read_text()) if p.exists() else {}
d['last_test_at'] = 'test'
p.write_text(json.dumps(d, indent=2))
\""
# 11. Obsidian MCP Brain E2E Verification
run_test "Obsidian Brain MCP tools & resources" "uv run --with-requirements '$MCP_ROOT/server/requirements.txt' python3 -c \"
import sys, pathlib
sys.path.append('$MCP_ROOT/server')
import main
# Test write
res = main.brain_write_note('test_note_mcp', 'ideas', '# Hello from test\\nThis is a test of workspace mcp brain.')
assert 'Successfully' in res, f'Write failed: {res}'
# Test read
content = main.brain_read_note('test_note_mcp')
assert 'Hello from test' in content, f'Read failed: {content}'
# Test search
s_res = main.brain_search('test_note_mcp')
assert 'test_note_mcp' in s_res, f'Search failed: {s_res}'
# Test link
link_res = main.brain_link_notes('test_note_mcp', 'another_note')
assert 'Successfully' in link_res, f'Link failed: {link_res}'
# Test resource
ideas_res = main.res_brain_ideas()
assert 'test_note_mcp' in ideas_res, f'Resource listing failed: {ideas_res}'
# Cleanup
pathlib.Path('$WORKSPACE/brain/ideas/test_note_mcp.md').unlink()
\""# 12. Approved MCP Connectors E2E Verification
run_test "System MCP connectors (github, filesystem, shortcuts, search)" "uv run --with-requirements '$MCP_ROOT/server/requirements.txt' python3 -c \"
import sys, pathlib, json
sys.path.append('$MCP_ROOT/server')
import main

# Test GitHub tool
prs = main.github_list_prs()
assert prs is not None, 'github_list_prs failed'

# Test Filesystem tool
files = json.loads(main.filesystem_list_dir('.'))
assert len(files) > 0, 'filesystem_list_dir failed'

# Test Shortcuts tool
shortcuts = json.loads(main.shortcuts_list())
assert len(shortcuts) > 0, 'shortcuts_list failed'

# Test Brave Search tool
search = json.loads(main.search_web_brave('model context protocol'))
assert len(search) > 0, 'search_web_brave failed'

# Test new resources
assert 'GitHub' in main.res_github_status(), 'res_github_status failed'
assert 'Filesystem' in main.res_filesystem_status(), 'res_filesystem_status failed'
assert 'Shortcuts' in main.res_shortcuts_status(), 'res_shortcuts_status failed'
assert 'Search' in main.res_search_status(), 'res_search_status failed'
\""

echo ""
echo "=============================="
echo "Passed: $PASS | Failed: $FAIL"
if [ "$FAIL" -eq 0 ]; then
    echo "Status: ALL TESTS PASS"
    exit 0
else
    echo "Status: $FAIL TEST(S) FAILED"
    exit 1
fi
