#!/bin/sh
set -eu

ROOT="${SUNEEL_WORKSPACE:-$HOME/SuneelWorkSpace}"
. "$ROOT/automation/maintenance/common.sh"

ensure_core_dirs
"$ROOT/bin/agent-doctor" --quiet >/dev/null 2>&1 || true

IDLE_CLOSEOUT="$(python3 - "$STATE_JSON" <<'PY'
import json, sys
from datetime import datetime

try:
    data = json.load(open(sys.argv[1]))
except Exception:
    print("no")
    raise SystemExit
if not data.get("active_session_detected"):
    print("no")
    raise SystemExit
stamp = data.get("last_activity_timestamp") or data.get("session_started_at")
if not stamp:
    print("yes")
    raise SystemExit
try:
    last = datetime.strptime(stamp, "%Y-%m-%dT%H:%M:%S%z")
    age = (datetime.now(last.tzinfo) - last).total_seconds()
except Exception:
    print("yes")
    raise SystemExit
print("yes" if age > 5400 else "no")
PY
)"

if [ "$IDLE_CLOSEOUT" = "yes" ]; then
  "$ROOT/bin/agent-autoclose" --reason inactivity --quiet >/dev/null 2>&1 || true
fi

NEEDS_REPAIR="$(python3 - "$HEALTH_JSON" <<'PY'
import json, sys
try:
    data = json.load(open(sys.argv[1]))
except Exception:
    print("yes")
    raise SystemExit
print("yes" if data.get("error_count", 0) or data.get("warning_count", 0) else "no")
PY
)"

if [ "$NEEDS_REPAIR" = "yes" ]; then
  "$ROOT/bin/agent-repair" --quiet >/dev/null 2>&1 || true
fi

"$ROOT/bin/workspace-index" --quiet >/dev/null 2>&1 || true
"$ROOT/bin/workspace-report" --quiet >/dev/null 2>&1 || true
if [ -x "$ROOT/autolab/scripts/autolab-watch" ]; then
  "$ROOT/autolab/scripts/autolab-watch" >/dev/null 2>&1 || true
fi
if [ -x "$ROOT/autolab/scripts/autolab-once" ]; then
  RUN_AUTOLAB_ONCE="$(python3 - "$ROOT/autolab/state/latest_eval.json" "$ROOT/autolab/state/loop_status.json" <<'PY'
import json, pathlib, sys, time
eval_path = pathlib.Path(sys.argv[1])
status_path = pathlib.Path(sys.argv[2])
try:
    latest = json.loads(eval_path.read_text())
except Exception:
    print("no")
    raise SystemExit
try:
    status = json.loads(status_path.read_text())
except Exception:
    status = {}
score = float(latest.get("score", 100))
last = status.get("last_run_at")
old_enough = True
if last:
    try:
        import datetime
        dt = datetime.datetime.strptime(last, "%Y-%m-%dT%H:%M:%S%z")
        old_enough = (datetime.datetime.now(dt.tzinfo) - dt).total_seconds() > 86400
    except Exception:
        old_enough = True
print("yes" if score < 100 and old_enough else "no")
PY
)"
  if [ "$RUN_AUTOLAB_ONCE" = "yes" ]; then
    "$ROOT/autolab/scripts/autolab-once" >/dev/null 2>&1 || true
  fi
fi
"$ROOT/bin/workspace-backup" --maintenance --quiet >/dev/null 2>&1 || true

# MCP subsystem: lightweight health check and conditional reindex
if [ -x "$ROOT/mcp/server/scripts/mcp-doctor" ]; then
  "$ROOT/mcp/server/scripts/mcp-doctor" >/dev/null 2>&1 || true
fi
if [ -x "$ROOT/mcp/server/scripts/mcp-reindex" ]; then
  # Reindex if index is missing or older than 24 hours
  DB="$ROOT/mcp/server/storage/memory_index.db"
  SHOULD_REINDEX="$(python3 - "$DB" <<'MCPPY'
import pathlib, sys, time
db = pathlib.Path(sys.argv[1])
if not db.exists():
    print("yes")
elif (time.time() - db.stat().st_mtime) > 86400:
    print("yes")
else:
    print("no")
MCPPY
)"
  if [ "$SHOULD_REINDEX" = "yes" ]; then
    "$ROOT/mcp/server/scripts/mcp-reindex" >/dev/null 2>&1 || true
  fi
fi

# gstack supply chain integrity check
if [ -f "$ROOT/bin/gstack-verify" ]; then
  GSTACK_STATUS="$(python3 "$ROOT/bin/gstack-verify" --json 2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('status','error'))" 2>/dev/null || echo "error")"
  if [ "$GSTACK_STATUS" != "ok" ]; then
    # Log drift as a warning but do NOT auto-repair — requires human confirmation
    DRIFT_MSG="gstack integrity drift detected (status: $GSTACK_STATUS) — run bin/gstack-repair to inspect"
    python3 - "$ROOT/agent-system/logs/MAINTENANCE_LOG.md" "$DRIFT_MSG" <<'GSTACKPY'
import sys, pathlib
from datetime import datetime, timezone
log = pathlib.Path(sys.argv[1])
msg = sys.argv[2]
stamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
log.parent.mkdir(parents=True, exist_ok=True)
with open(log, "a") as f:
    f.write(f"\n## {stamp} agent-maintain\nWARNING: {msg}\n")
GSTACKPY
  fi
fi

# headroom proxy running check
if ! nc -z 127.0.0.1 8787 >/dev/null 2>&1; then
  python3 - "$ROOT/agent-system/logs/MAINTENANCE_LOG.md" "Headroom proxy is not running on port 8787 — context compression is inactive" <<'HEADROOMWARPY'
import sys, pathlib
from datetime import datetime, timezone
log = pathlib.Path(sys.argv[1])
msg = sys.argv[2]
stamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
log.parent.mkdir(parents=True, exist_ok=True)
with open(log, "a") as f:
    f.write(f"\n## {stamp} agent-maintain\nWARNING: {msg}\n")
HEADROOMWARPY
fi


# Communications subsystem: lightweight health check
if [ -f "$ROOT/comms/imessage/scripts/imessage-status" ]; then
  IMSG_STATUS="$(python3 "$ROOT/comms/imessage/scripts/imessage-status" 2>/dev/null | grep "Full Disk Access" | head -1 || echo "")"
  if echo "$IMSG_STATUS" | grep -q "DENIED"; then
    python3 - "$ROOT/agent-system/logs/MAINTENANCE_LOG.md" "iMessage FDA denied — grant Full Disk Access in System Settings" <<'COMMSWARPY'
import sys, pathlib
from datetime import datetime, timezone
log = pathlib.Path(sys.argv[1])
msg = sys.argv[2]
stamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
log.parent.mkdir(parents=True, exist_ok=True)
with open(log, "a") as f:
    f.write(f"\n## {stamp} agent-maintain\nWARNING: {msg}\n")
COMMSWARPY
  fi
fi

# Orchestrator: run route-learn to update patterns from history + autolab
if [ -f "$ROOT/orchestrator/scripts/route-learn" ]; then
  # Only run if there is routing history to learn from
  HISTORY_COUNT="$(python3 - "$ROOT/orchestrator/router/history.json" <<'ORCHPY'
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
try:
    d = json.loads(p.read_text())
    print(len(d.get("entries", [])))
except Exception:
    print(0)
ORCHPY
)"
  if [ "${HISTORY_COUNT:-0}" -gt 0 ] 2>/dev/null; then
    python3 "$ROOT/orchestrator/scripts/route-learn" --summary >/dev/null 2>&1 || true
  fi
fi

# Goal engine: lightweight monitor (no agent launch, safe)
if [ -f "$ROOT/goal-engine/graph/task_graph.json" ]; then
  python3 "$ROOT/goal-engine/scripts/goal-monitor" --quiet >/dev/null 2>&1 || true
fi

python3 - "$STATE_JSON" "$(now_stamp)" <<'PY'
import json, pathlib, sys
path = pathlib.Path(sys.argv[1])
stamp = sys.argv[2]
try:
    data = json.loads(path.read_text())
except Exception:
    data = {}
data["state_updated_at"] = stamp
data["status"] = "maintained"
data["last_maintenance_at"] = stamp
tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
tmp.replace(path)
PY

log_maintenance "Maintenance ran."
echo "Maintenance completed."
