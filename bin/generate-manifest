# ── Main ─────────────────────────────────────────────────────────────────────

def main() -> int:
    dry_run  = "--dry-run" in sys.argv
    validate = "--validate" in sys.argv

    manifest = build_manifest()

    if validate and SCHEMA_PATH.exists():
        try:
            import jsonschema
            schema = json.loads(SCHEMA_PATH.read_text())
            jsonschema.validate(manifest, schema)
            print("  [generate-manifest] Schema validation: PASS")
        except ImportError:
            print("  [generate-manifest] jsonschema not installed — skipping validation")
        except Exception as e:
            print(f"  [generate-manifest] Schema validation FAILED: {e}")

    text = json.dumps(manifest, indent=2)

    if dry_run:
        print(text)
        return 0

    OUT_PATH.write_text(text)
    print(f"  [generate-manifest] Written: {OUT_PATH} ({len(text):,} chars)")
    print(f"  [generate-manifest] Commands: {manifest['command_registry']['total_commands']}")
    print(f"  [generate-manifest] NLU intents: {manifest['nlu_pipeline']['intent_count']}")
    print(f"  [generate-manifest] NLU fixtures: {manifest['nlu_pipeline']['fixture_count']}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
