        "generated_at":   datetime.now(timezone.utc).isoformat(),
        "generated_by":   "bin/generate-manifest",
        "system_identity": {
            "name":        "Adwi",
            "operator":    "Suneel Bikkasani",
            "repo_root":   "~/SuneelWorkSpace",
            "entry_point": "bin/adwi → python3 adwi/adwi_cli.py",
            "description": "Local AI operating system running on Apple Silicon Mac. Terminal REPL + daemon services."
