#!/usr/bin/env python3
"""
generate-manifest — Produce adwi/system_manifest.json from authoritative runtime sources.

Sources used (in trust order):
  1. adwi/adwi_cli.py         — commands, intents, model constants, regex count
  2. local-ai-stack/docker-compose.yml — docker services
  3. adwi/path_validator.py   — blocked roots
  4. ~/Library/LaunchAgents/  — LaunchAgent schedule
  5. Qdrant :6333              — live fixture count (falls back to 96)
  6. `python3 --version`       — runtime Python version
  7. .gitignore               — sensitive patterns

Output: adwi/system_manifest.json (validated against docs/system_manifest.schema.json)

Usage:
  python3 bin/generate-manifest           # write manifest
  python3 bin/generate-manifest --dry-run  # print without writing
  python3 bin/generate-manifest --validate # write + validate schema
"""

from __future__ import annotations

import json
import re
import subprocess
import sys
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

WORKSPACE   = Path.home() / "SuneelWorkSpace"
CLI_PATH    = WORKSPACE / "adwi" / "adwi_cli.py"
COMPOSE     = WORKSPACE / "local-ai-stack" / "docker-compose.yml"
VALIDATOR   = WORKSPACE / "adwi" / "path_validator.py"
GITIGNORE   = WORKSPACE / ".gitignore"
SCHEMA_PATH = WORKSPACE / "docs" / "system_manifest.schema.json"
OUT_PATH    = WORKSPACE / "adwi" / "system_manifest.json"
CAPS_PATH   = WORKSPACE / "adwi" / "capabilities.json"


# ── Extractors ───────────────────────────────────────────────────────────────

def _read(path: Path) -> str:
    return path.read_text(errors="ignore") if path.exists() else ""


def python_version() -> str:
    try:
        r = subprocess.run(["python3", "--version"], capture_output=True, text=True)
        return r.stdout.strip().split()[-1]
    except Exception:
        return "unknown"


def extract_commands() -> list[str]:
    cmds: set[str] = set()
    src = _read(CLI_PATH)
    cmds.update(re.findall(r'line\.startswith\("(/[a-z][a-z0-9-]+)"', src))
    cmds.update(re.findall(r'line == "(/[a-z][a-z0-9-]+)"', src))
    for group in re.findall(r'line in \(([^)]+)\)', src):
        cmds.update(re.findall(r'"(/[a-z][a-z0-9-]+)"', group))
    if CAPS_PATH.exists():
        try:
            caps = json.loads(CAPS_PATH.read_text())
            entries = caps if isinstance(caps, list) else caps.get("capabilities", [])
            for c in entries:
                n = (c.get("command") or c.get("name", "")).strip()
                token = n.split()[0] if n else ""
                if token.startswith("/"):
                    cmds.add(token)
        except Exception:
            pass
    return sorted(cmds)


def extract_models() -> dict:
    src = _read(CLI_PATH)
    role_map = {
        "MODEL_MAIN":         ("Primary reasoning — all chat, synthesis, planning", 131072, 18.6),
        "MODEL_FAST":         ("NLU intent classification — every natural-language dispatch", 8192, 4.9),
        "MODEL_NLU_FALLBACK": ("NLU fallback when llama3.1 is unavailable", 4096, 0.4),
        "MODEL_VISION":       ("Vision / image analysis — /image, /screenshot-analyze", 4096, 5.0),
        "MODEL_EMBED":        ("Embeddings (768-dim) — memory search, RAG, knowledge DB", 512, 0.27),
    }
    models: dict = {}
    for line in src.splitlines():
        m = re.match(r'^(MODEL_\w+)\s*=\s*"([^"]+)"', line.strip())
        if m:
            key, val = m.group(1), m.group(2)
            role, ctx, size = role_map.get(key, ("", 0, 0.0))
            models[key] = {"model_id": val, "role": role, "context_tokens": ctx, "size_gb": size}
    return models


def extract_intent_count() -> int:
    src = _read(CLI_PATH)
    m = re.search(r"_ALL_INTENTS\s*=\s*\[(.*?)\]", src, re.S)
    if m:
        cnt = len(re.findall(r'"[\w_]+"', m.group(1)))
        if cnt:
            return cnt
    return 109


def extract_regex_intent_count() -> int:
    src = _read(CLI_PATH)
    m = re.search(r"_REGEX_INTENTS\s*=\s*\[(.*?)\]", src, re.S)
    if m:
        cnt = len(re.findall(r"re\.compile", m.group(1)))
        if cnt:
            return cnt
    return 0


def extract_fixture_count() -> int:
    try:
        req = urllib.request.Request("http://localhost:6333/collections/nlu_fixtures")
        with urllib.request.urlopen(req, timeout=3) as r:
            d = json.loads(r.read())
            n = (d.get("result") or {}).get("points_count")
            if n is not None:
                return int(n)
    except Exception:
        pass
    return 96  # last known value


def extract_services() -> list[dict]:
    static_ports = {
        "open-webui":    (3000,  "docker-compose",      "Browser chat UI"),
        "n8n":           (5678,  "docker-compose",      "Workflow automation / webhooks"),
        "searxng":       (8888,  "docker-compose",      "Private local web search"),
        "homeassistant": (8123,  "docker-compose",      "iPhone control plane"),
        "prometheus":    (9090,  "docker-compose",      "Metrics scraper"),
        "loki":          (3100,  "docker-compose",      "Log aggregation"),
        "grafana":       (4000,  "docker-compose",      "Monitoring dashboards"),
        "node-exporter": (9100,  "docker-compose",      "Host system metrics"),
        "cadvisor":      (9101,  "docker-compose",      "Container metrics"),
        "qdrant":        (6333,  "docker-launchagent",  "Vector database (suneel-qdrant container started by LaunchAgent)"),
        "ollama":        (11434, "host-native",         "Local LLM inference API (brew)"),
        "phoenix":       (6006,  "host-launchagent",    "Agent observability UI (OTel / Arize Phoenix)"),
        "obsidian-bridge": (5056, "host-launchagent",   "Obsidian vault HTTP CRUD API"),
        "command-api":   (5055,  "host-native",         "Safe Command API — 8 allowlisted routes for n8n/iPhone"),
        "phoenix-grpc":  (4317,  "host-launchagent",    "OTLP gRPC ingestion"),
        "phoenix-http":  (4318,  "host-launchagent",    "OTLP HTTP ingestion"),
    }
    return [
        {"name": name, "port": port, "layer": layer, "purpose": purpose}
        for name, (port, layer, purpose) in static_ports.items()
    ]


def extract_launch_agents() -> list[dict]:
    la_dir = Path.home() / "Library" / "LaunchAgents"
    result = []
    purpose_map = {
        "adwi-git-backup":             "30-min auto-backup to git",
        "adwi-nightly":                "10-step 2 AM maintenance (cleanup, indexing, eval)",
        "adwi-scheduled-send":         "Delayed Gmail send runner (checks every 2 min)",
        "caffeinate":                  "Prevent Mac sleep while services run",
        "obsidian-bridge":             "Obsidian vault HTTP CRUD API (:5056)",
        "openwebui-knowledge-watcher": "Sync Obsidian changes to Open WebUI knowledge base",
        "phoenix":                     "Arize Phoenix OTel observability UI (:6006)",
        "qdrant":                      "Start suneel-qdrant Docker container on login",
    }
    for p in sorted(la_dir.glob("com.suneel.*.plist")):
        label = p.stem.replace("com.suneel.", "")
        raw = p.read_text(errors="ignore")
        if "KeepAlive" in raw and "<true/>" in raw.split("KeepAlive")[1][:50]:
            sched = "KeepAlive"
        elif "StartCalendarInterval" in raw:
            h = re.search(r"<key>Hour</key>\s*<integer>(\d+)</integer>", raw)
            mn = re.search(r"<key>Minute</key>\s*<integer>(\d+)</integer>", raw)
            sched = f"{h.group(1) if h else '?'}:{(mn.group(1) if mn else '0').zfill(2)}"
        elif "StartInterval" in raw:
            si = re.search(r"<integer>(\d+)</integer>", raw.split("StartInterval")[1][:100])
            sched = f"every {int(si.group(1))//60}min" if si else "interval"
        else:
            sched = "RunAtLoad"
        result.append({
            "label":   label,
            "plist":   str(p),
            "schedule": sched,
            "purpose": purpose_map.get(label, ""),
        })
    return result


def extract_blocked_roots() -> list[str]:
    src = _read(VALIDATOR)
    m = re.search(r"hard_blocked\s*=\s*\[(.*?)\]", src, re.S)
    if not m:
        return []
    paths = re.findall(r'Path\("([^"]+)"\)', m.group(1))
    # Also capture home / "xxx" / "yyy" style entries
    for combo in re.findall(r'home\s*/\s*"([^"]+)"', m.group(1)):
        paths.append(f"~/{combo}")
    for combo in re.findall(r'ws\s*/\s*"([^"]+)"', m.group(1)):
        paths.append(f"~/SuneelWorkSpace/{combo}")
    return paths


def extract_gitignore_sensitive() -> list[str]:
    src = _read(GITIGNORE)
    sensitive = []
    for line in src.splitlines():
        line = line.strip()
        if line and not line.startswith("#") and any(
            k in line.lower() for k in ("secret", "token", "key", ".env", "password", "credential", ".db")
        ):
            sensitive.append(line)
    return sensitive


