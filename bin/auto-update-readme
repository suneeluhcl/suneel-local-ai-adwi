    lines = ["| Port | Service | Layer | Purpose |", "|---|---|---|---|"]
    for port, svc, layer, purpose in PORTS:
        lines.append(f"| {port} | {svc} | {layer} | {purpose} |")
    return "\n".join(lines)


def build_commands_section(snap: dict) -> str:
    """Rich capability grid: command groups with descriptions parsed from HELP."""
    cmds = snap["commands"]

    # Try to load descriptions from adwi_cli.py HELP string
    descriptions: dict[str, str] = {}
    if CLI_PATH.exists():
        src = CLI_PATH.read_text(errors="ignore")
        # Extract HELP string
        hs = src.find('HELP = f"""')
        he = src.find('""".strip()', hs + 1) if hs != -1 else -1
        if hs != -1 and he != -1:
            help_text = re.sub(r'\{[A-Z_]+\}', '', src[hs + len('HELP = f"""'):he])
            for line in help_text.splitlines():
                s = line.strip()
                if not s.startswith("/"): continue
                parts = re.split(r"\s{2,}", s, maxsplit=1)
                if len(parts) < 2: continue
                for tok in re.findall(r"/[\w/-]+", parts[0]):
                    if tok not in descriptions:
                        descriptions[tok] = parts[1].strip()

    # Group commands by first word segment
    groups: dict[str, list[str]] = {}
    for c in cmds:
        key = c.lstrip("/").split("-")[0]
        groups.setdefault(key, []).append(c)

    lines = [f"**{len(cmds)} registered commands.** Key groups:\n"]
    for grp, items in sorted(groups.items()):
        lines.append(f"**{grp}**: " + "  ".join(f"`{i}`" for i in sorted(items)))

    return "\n".join(lines)


