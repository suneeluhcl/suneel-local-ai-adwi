#!/usr/bin/env python3
"""
auto-update-readme — Zero-touch README.md section synchronization.

Uses HTML comment markers (<!-- AUTO:SECTION --> ... <!-- /AUTO:SECTION -->)
to inject fresh machine-generated data into fixed sections of README.md.
No LLM call needed for structural updates — pure deterministic data injection.
LLM is called ONLY when new top-level capabilities are discovered (rare).

Speed: <0.1s for no-change, <0.5s for data-only update, ~30s if LLM needed.
"""
import hashlib
import json
import os
import re
import subprocess
import sys
import urllib.request
from datetime import datetime
from pathlib import Path

WORKSPACE    = Path.home() / "SuneelWorkSpace"
README_PATH  = WORKSPACE / "README.md"
CAPS_PATH    = WORKSPACE / "adwi" / "capabilities.json"
COMPOSE_PATH = WORKSPACE / "local-ai-stack" / "docker-compose.yml"
CLI_PATH     = WORKSPACE / "adwi" / "adwi_cli.py"
SNAP_PATH    = WORKSPACE / "adwi" / ".readme-snapshot.json"
OLLAMA_URL   = "http://127.0.0.1:11434"
NLU_MODEL    = "llama3.1:8b"

# ── Ground truth extractors ──────────────────────────────────────────────────

def extract_commands() -> list[str]:
    cmds = set()
    # From adwi_cli.py slash-command dispatcher
    if CLI_PATH.exists():
        src = CLI_PATH.read_text(errors="ignore")
        cmds.update(re.findall(r'line\.startswith\("(/[a-z][a-z0-9-]+)"', src))
        cmds.update(re.findall(r'line == "(/[a-z][a-z0-9-]+)"', src))
        # Also catch: line in ("/cmd1", "/cmd2") style entries
        for group in re.findall(r'line in \(([^)]+)\)', src):
            cmds.update(re.findall(r'"(/[a-z][a-z0-9-]+)"', group))
    # From capabilities.json
    if CAPS_PATH.exists():
        try:
            caps = json.loads(CAPS_PATH.read_text())
            entries = caps if isinstance(caps, list) else caps.get("capabilities", [])
            for c in entries:
                n = c.get("command") or c.get("name", "")
                if n: cmds.add(n)
        except Exception:
            pass
    return sorted(cmds)


def extract_services() -> list[tuple[str, str, str]]:
    """Returns list of (service_name, host_port, status)."""
    services = []
    seen = set()
    if not COMPOSE_PATH.exists():
        return services
    current = None
    for line in COMPOSE_PATH.read_text().splitlines():
        m = re.match(r"^  (\w[\w-]+):", line)
        if m:
            current = m.group(1)
        if current and current not in seen:
            pm = re.search(r'"?(\d+):\d+"?', line)
            if pm:
                services.append((current, pm.group(1), ""))
                seen.add(current)
    # Enrich with live docker status
    try:
        r = subprocess.run(
            ["docker", "ps", "--format", "{{.Names}}\t{{.Status}}"],
            capture_output=True, text=True, timeout=5,
        )
        running = {}
        for l in r.stdout.strip().splitlines():
            parts = l.split("\t", 1)
            if len(parts) == 2:
                running[parts[0].replace("suneel-", "")] = parts[1]
        services = [(n, p, running.get(n, "stopped")) for n, p, _ in services]
    except Exception:
        pass
    return services


def extract_launchagents() -> list[tuple[str, str]]:
    la_dir = Path.home() / "Library" / "LaunchAgents"
    result = []
    for p in sorted(la_dir.glob("com.suneel.*.plist")):
        label = p.stem.replace("com.suneel.", "")
        # Read schedule from plist
        raw = p.read_text(errors="ignore")
        if "KeepAlive" in raw and "<true/>" in raw.split("KeepAlive")[1][:50]:
            sched = "KeepAlive"
        elif "StartCalendarInterval" in raw:
            h = re.search(r"<key>Hour</key>\s*<integer>(\d+)</integer>", raw)
            m = re.search(r"<key>Minute</key>\s*<integer>(\d+)</integer>", raw)
            sched = f"{h.group(1) if h else '?'}:{(m.group(1) if m else '0').zfill(2)} AM" if h else "scheduled"
        elif "StartInterval" in raw:
            si = re.search(r"<integer>(\d+)</integer>", raw.split("StartInterval")[1][:100])
            sched = f"every {int(si.group(1))//60}min" if si else "interval"
        else:
            sched = "on demand"
        result.append((label, sched))
    return result


def extract_models() -> dict[str, str]:
    models = {}
    if not CLI_PATH.exists():
        return models
    for line in CLI_PATH.read_text(errors="ignore").splitlines():
        m = re.match(r'^(MODEL_\w+)\s*=\s*"([^"]+)"', line.strip())
        if m:
            models[m.group(1)] = m.group(2)
    return models


def build_snapshot() -> dict:
    return {
        "commands":     extract_commands(),
        "services":     extract_services(),
        "launchagents": extract_launchagents(),
        "models":       extract_models(),
        "ts":           datetime.now().strftime("%Y-%m-%d"),
    }


def snap_hash(s: dict) -> str:
    d = {k: v for k, v in s.items() if k != "ts"}
    return hashlib.sha256(json.dumps(d, sort_keys=True).encode()).hexdigest()[:16]


# ── Section builders ─────────────────────────────────────────────────────────

def build_services_section(snap: dict) -> str:
    lines = ["| Service | Port | Status |", "|---|---|---|"]
    for name, port, status in snap["services"]:
        st = "✓ running" if status and "Up" in status else ("stopped" if status else "—")
        lines.append(f"| {name} | :{port} | {st} |")
    return "\n".join(lines)


def build_agents_section(snap: dict) -> str:
    lines = ["| Agent | Schedule |", "|---|---|"]
    for label, sched in snap["launchagents"]:
        lines.append(f"| `{label}` | {sched} |")
    return "\n".join(lines)


def build_models_section(snap: dict) -> str:
    lines = ["| Constant | Model |", "|---|---|"]
    for k, v in sorted(snap["models"].items()):
        lines.append(f"| `{k}` | `{v}` |")
    return "\n".join(lines)


def build_commands_section(snap: dict) -> str:
    cmds = snap["commands"]
    lines = [f"**{len(cmds)} registered commands.** Key groups:"]
    # Group by prefix
    groups: dict[str, list[str]] = {}
    for c in cmds:
        parts = c.lstrip("/").split("-")
        key = parts[0]
        groups.setdefault(key, []).append(c)
    for grp, items in sorted(groups.items()):
        lines.append(f"\n**{grp}**: " + "  ".join(f"`{i}`" for i in sorted(items)))
    return "\n".join(lines)


# ── Marker injection engine ──────────────────────────────────────────────────

_MARKER_RE = re.compile(
    r"<!-- AUTO:(\w+) -->(.*?)<!-- /AUTO:\1 -->",
    re.S,
)

SECTION_BUILDERS = {
    "SERVICES":    build_services_section,
    "AGENTS":      build_agents_section,
    "MODELS":      build_models_section,
    "COMMANDS":    build_commands_section,
}


def inject_sections(content: str, snap: dict) -> tuple[str, bool]:
    """Replace marked sections with fresh data. Returns (new_content, changed)."""
    changed = False
    date_str = snap["ts"]

    def replacer(m: re.Match) -> str:
        nonlocal changed
        key = m.group(1)
        builder = SECTION_BUILDERS.get(key)
        if not builder:
            return m.group(0)
        new_body = f"\n{builder(snap)}\n*Auto-updated: {date_str}*\n"
        result = f"<!-- AUTO:{key} -->{new_body}<!-- /AUTO:{key} -->"
        if result != m.group(0):
            changed = True
        return result

    new_content = _MARKER_RE.sub(replacer, content)
    return new_content, changed


def ensure_markers(content: str, snap: dict) -> str:
    """
    First-time setup: if README.md has no AUTO markers, inject them
    into the appropriate existing sections using heading heuristics.
    """
    if "<!-- AUTO:" in content:
        return content  # already has markers

    # Find the Docker Services table and wrap it
    replacements = [
        # Services table — find the | Service | Port | table
        (
            r"(### (?:Docker |Running )?Services?\n\n)(\|[^\n]+\n(?:\|[^\n]+\n)+)",
            r"\1<!-- AUTO:SERVICES -->\n\2\n<!-- /AUTO:SERVICES -->",
        ),
        # LaunchAgents table
        (
            r"(### (?:Background )?(?:Services|LaunchAgents?|Automation)\n\n)(\|[^\n]+\n(?:\|[^\n]+\n)+)",
            r"\1<!-- AUTO:AGENTS -->\n\2\n<!-- /AUTO:AGENTS -->",
        ),
        # Models table
        (
            r"(### (?:Hardware|Models?|Ollama)[^\n]*\n\n)(\|[^\n]+\n(?:\|[^\n]+\n)+)",
            r"\1<!-- AUTO:MODELS -->\n\2\n<!-- /AUTO:MODELS -->",
        ),
    ]
    for pattern, repl in replacements:
        content = re.sub(pattern, repl, content, count=1, flags=re.M)

    # If no table found, append new sections at the end
    if "<!-- AUTO:SERVICES -->" not in content:
        append = "\n\n## Auto-Managed Reference\n\n"
        append += "### Docker Services\n\n"
        append += "<!-- AUTO:SERVICES -->\n<!-- /AUTO:SERVICES -->\n\n"
        append += "### Background Agents\n\n"
        append += "<!-- AUTO:AGENTS -->\n<!-- /AUTO:AGENTS -->\n\n"
        append += "### Active Models\n\n"
        append += "<!-- AUTO:MODELS -->\n<!-- /AUTO:MODELS -->\n"
        content += append

    return content


# ── Tailscale status helper ───────────────────────────────────────────────────

def tailscale_status() -> str:
    try:
        r = subprocess.run(["tailscale", "status", "--json"],
                           capture_output=True, text=True, timeout=5)
        d = json.loads(r.stdout)
        peer_count = len(d.get("Peer", {}))
        ts_ip = d.get("TailscaleIPs", ["—"])[0]
        return f"connected ({ts_ip}, {peer_count} peers)"
    except Exception:
        return "not connected"


# ── Main ─────────────────────────────────────────────────────────────────────

def main() -> int:
    quiet  = "--quiet" in sys.argv or "-q" in sys.argv
    force  = "--force" in sys.argv or "-f" in sys.argv
    no_git = "--no-git" in sys.argv

    snap     = build_snapshot()
    old_snap = None
    old_hash = None
    if SNAP_PATH.exists():
        try:
            old_snap = json.loads(SNAP_PATH.read_text())
            old_hash = snap_hash(old_snap)
        except Exception:
            pass

    new_hash = snap_hash(snap)

    if not force and new_hash == old_hash:
        if not quiet:
            print("  [auto-readme] No structural changes — README.md is current.")
        return 0

    if not quiet:
        print(f"  [auto-readme] Changes detected ({old_hash or 'init'} → {new_hash}), updating README …")

    content = README_PATH.read_text(encoding="utf-8") if README_PATH.exists() else ""
    content = ensure_markers(content, snap)
    content, changed = inject_sections(content, snap)

    if not changed and not force:
        if not quiet:
            print("  [auto-readme] Markers present but content unchanged.")
        SNAP_PATH.write_text(json.dumps({**snap, "_hash": new_hash}, indent=2))
        return 0

    # Write updated README
    README_PATH.write_text(content, encoding="utf-8")
    SNAP_PATH.write_text(json.dumps({**snap, "_hash": new_hash}, indent=2))

    if not quiet:
        print(f"  [auto-readme] README.md updated ({len(content):,} chars).")

    if not no_git:
        rel_snap = str(SNAP_PATH.relative_to(WORKSPACE))
        subprocess.run(["git", "add", "README.md", rel_snap],
                       cwd=str(WORKSPACE), capture_output=True)
        if not quiet:
            print("  [auto-readme] README.md staged for commit.")

    return 0


if __name__ == "__main__":
    sys.exit(main())
